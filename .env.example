# ---------------------------------------------------------------------------
# Cherryflix environment variables
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# Neon Postgres connection string (https://neon.tech → your project → Connect)
# Looks like: postgresql://user:pass@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Resend API key (https://resend.com → API Keys)
RESEND_API_KEY=

# The "from" address for invite / sign-in emails.
# For testing you can use the shared sandbox sender below.
# For real invites, verify your own domain in Resend and use it here.
EMAIL_FROM="Cherryflix <onboarding@resend.dev>"

# Auth.js secret — generate one with:  npx auth secret
# (or:  openssl rand -base64 32)
AUTH_SECRET=

# The public URL of your site. Locally use http://localhost:3000
# On Vercel set this to your deployed URL, e.g. https://cherryflix.vercel.app
AUTH_URL=http://localhost:3000

# Your email(s) — these accounts can access the /admin dashboard.
# Comma-separated for more than one.
ADMIN_EMAILS=jerico.ursua1@gmail.com

# Owner password — lets you (an ADMIN_EMAILS account) sign in without email.
# Choose something private.
OWNER_PASSWORD=change-this-owner-password

# Gmail SMTP — send invite emails to anyone from your own Gmail (no domain needed).
# GMAIL_APP_PASSWORD = a 16-char "App Password" from Google Account → Security.
# (Preferred over Resend. If left blank, the app falls back to Resend.)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
